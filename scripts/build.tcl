#=========================================================
# Tang Nano 9K Build Script
#=========================================================

set_device GW1NR-LV9QN88PC6/I5

#---------------------------------------------------------
# RTL Sources
#---------------------------------------------------------
add_file ../rtl/counter.v
add_file ../rtl/top.v

#---------------------------------------------------------
# Constraints
#---------------------------------------------------------
add_file ../constraints/tangnano9k.cst
add_file ../constraints/tangnano9k.sdc

#---------------------------------------------------------
# Project Options
#---------------------------------------------------------
set_option -top_module top
set_option -output_base_name top

#---------------------------------------------------------
# Run Complete Flow
#---------------------------------------------------------
run all

exit
